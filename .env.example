# ===== Next.js (apps/web/.env.local) =====

# WalletConnect (get free project ID at https://cloud.reown.com)
NEXT_PUBLIC_WC_PROJECT_ID=

# Arc Testnet
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_EXPLORER=https://testnet.arcscan.app

# Deployed Leaderboard contract address (filled after deploy)
NEXT_PUBLIC_LEADERBOARD_ADDRESS=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (do NOT prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
SCORE_SIGNER_PRIVATE_KEY=
SERVER_HMAC_SECRET=

# ===== Hardhat (packages/contracts/.env) =====
DEPLOYER_PRIVATE_KEY=
ARC_RPC_URL=https://rpc.testnet.arc.network
SCORE_SIGNER_ADDRESS=
CONTRACT_OWNER_ADDRESS=
